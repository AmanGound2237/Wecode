# ----------------------------------------------------------------------------------
# Wecode Platform - Vercel Serverless Boilerplate Environment Variables
# ----------------------------------------------------------------------------------

# [ 1. DATABASE CONFIGURATION ]
# Replace this with your full Neon (Serverless PostgreSQL) direct connection string
DATABASE_URL=postgresql://user:password@hostname:5432/dbname?sslmode=require

# [ 2. AI CORE CONFIGURATION ]
# Provide your Google Gemini API key. Ensure the tier supports the `gemini-flash-latest` model.
GEMINI_API_KEY=your_gemini_api_key_here

# [ 3. AUTHENTICATION & SECURITY ]
# 32-character minimum cryptographic string used by Iron Session to encrypt cookies.
# (e.g. generate via `openssl rand -base64 32`)
SESSION_SECRET=your_32_character_complex_password_here

# Required for proper cookie signing on HTTPS in production
NODE_ENV=production
