generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIMEOUT
}

model User {
  id           String       @id @default(cuid())
  name         String?
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  submissions  Submission[]
  resetTokens  PasswordResetToken[]
  papers       ResearchPaper[]
}

model Problem {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  summary     String
  difficulty  Difficulty
  prompt      String
  inputFormat String
  outputFormat String
  constraints String[]
  starterCode String
  createdAt   DateTime      @default(now())
  topicId     String?
  topic       Topic?        @relation(fields: [topicId], references: [id])
  tags        ProblemTag[]
  submissions Submission[]
  examples    ProblemExample[]
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  problems ProblemTag[]
}

model Topic {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  category  String?
  summary   String
  theory    String
  videoUrl  String
  createdAt DateTime  @default(now())
  problems  Problem[]
}

model ProblemTag {
  problemId String
  tagId     String
  problem   Problem @relation(fields: [problemId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([problemId, tagId])
}

model Submission {
  id         String           @id @default(cuid())
  userId     String?
  problemId  String
  status     SubmissionStatus @default(PENDING)
  runtimeMs  Int?
  memoryMb   Float?
  language   String           @default("python")
  code       String
  output     String
  createdAt  DateTime         @default(now())

  user       User?            @relation(fields: [userId], references: [id])
  problem    Problem          @relation(fields: [problemId], references: [id])
}

model ProblemExample {
  id          String   @id @default(cuid())
  problemId   String
  input       String
  output      String
  explanation String?
  order       Int      @default(0)

  problem     Problem  @relation(fields: [problemId], references: [id])

  @@index([problemId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ══════════════════════════════════════════════════════════
// CODE WITH AI — Research Paper Learning Pipeline
// ══════════════════════════════════════════════════════════

enum PaperStatus {
  UPLOADING
  ANALYZING
  READY
  ERROR
}

enum StepStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

model ResearchPaper {
  id              String        @id @default(cuid())
  userId          String
  title           String
  authors         String[]
  abstract        String
  sourceUrl       String?
  rawContent      String        // Full extracted text
  status          PaperStatus   @default(UPLOADING)
  analysisCache   Json?         // Cached Gemini analysis
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  prerequisites   Prerequisite[]
  steps           ImplementationStep[]
  synthesis       Synthesis?

  @@index([userId])
}

model Prerequisite {
  id              String   @id @default(cuid())
  paperId         String
  title           String
  description     String
  resourceUrl     String?
  resourceType    String?        // "video", "article", "documentation", "course", "paper"
  order           Int      @default(0)
  isCompleted     Boolean  @default(false)

  paper           ResearchPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model ImplementationStep {
  id              String     @id @default(cuid())
  paperId         String
  title           String
  description     String     // AI-generated task description
  hints           String[]
  starterCode     String
  solutionCode    String?
  testCases       Json?      // Array of {input, expectedOutput}
  order           Int        @default(0)
  status          StepStatus @default(LOCKED)
  userCode        String?
  completedAt     DateTime?

  paper           ResearchPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model Synthesis {
  id              String   @id @default(cuid())
  paperId         String   @unique
  whySummary      String   // "Why does this paper matter?"
  industryUses    Json     // Array of {company, useCase, description}
  keyTakeaways    String[]
  furtherReading  Json?    // Array of {title, url}

  paper           ResearchPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
}
